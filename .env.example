# Supabase (Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your_supabase_key

# LiveKit (frontend only — no secrets)
VITE_LIVEKIT_URL=wss://your-project.livekit.cloud

# Your Google email becomes super admin on first login (unlimited coins, join any room)
VITE_SUPER_ADMIN_EMAIL=your@gmail.com

# If using sb_publishable_ key: Edge Functions → livekit-token → turn OFF "Verify JWT"

# Socket.io mini-games server (local dev only — .env.production has the live Render URL)
VITE_SOCKET_URL=http://localhost:3001
# Live site: deploy render.yaml on Render (free), then rebuild with `npm run deploy`
# Production URL is in .env.production → https://g-play-socket.onrender.com
