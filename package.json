    "livekit-client": "^2.19.1",
    "lottie-web": "^5.13.0",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "svgaplayerweb": "^2.3.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
